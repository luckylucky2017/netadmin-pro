# Sao chép file này thành .env và điền giá trị thật
# API key của Anthropic để bật phân tích Excel bằng Claude AI và chatbot AI.
# Không có key: phân tích Excel tự chạy ở chế độ heuristic; chatbot trả lỗi rõ ràng khi gọi.
ANTHROPIC_API_KEY=

# Cổng chạy server (mặc định 3000)
PORT=3000

# ── Database (MySQL) ─────────────────────────────────────────────────────
# Dùng 1 user riêng chỉ có quyền trên đúng 1 database của app, không dùng root cho app.
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=

# SSH collector: đường dẫn private key dùng để thu thập CPU/RAM/Disk thật từ các server
# đã khai báo "SSH User" trong trang Máy chủ. Server cần có public key tương ứng trong
# ~/.ssh/authorized_keys. Mặc định dùng ~/.ssh/id_rsa nếu không đặt biến này.
SSH_PRIVATE_KEY_PATH=
# Nếu private key có passphrase
SSH_PASSPHRASE=

# vCenter: đồng bộ inventory VM (tên, trạng thái, vCPU, RAM) mỗi 60s. Để trống nếu chưa dùng vCenter.
VCENTER_HOST=
VCENTER_USER=
VCENTER_PASSWORD=
# vCenter dùng chứng chỉ tự ký mặc định — để true để bỏ qua xác thực cert
VCENTER_INSECURE=true

# ── Đăng nhập & phân quyền ──────────────────────────────────────────────
# Khóa ký session cookie — giữ bí mật, đổi giá trị này sẽ đăng xuất tất cả user đang đăng nhập.
# Tạo 1 chuỗi ngẫu nhiên dài, ví dụ: openssl rand -hex 32
SESSION_SECRET=

# Tài khoản admin đầu tiên — chỉ được tạo 1 lần lúc bảng users còn rỗng. Đổi mật khẩu ngay sau khi
# đăng nhập lần đầu (trang Người dùng), 2 biến này không dùng lại sau đó.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# SSO qua SAML (vd: Google Workspace làm IdP) — để trống nếu chưa dùng SSO SAML.
SAML_IDP_ENTRY_POINT=
SAML_IDP_CERT=
SAML_IDP_ISSUER=
SAML_SP_ENTITY_ID=netadmin-pro
SAML_SP_CALLBACK_URL=

# SSO qua LDAP/Active Directory (bind-auth trực tiếp) — để trống nếu chưa dùng LDAP.
LDAP_URL=
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=
LDAP_BASE_DN=
# {{username}} được thay bằng username user nhập lúc đăng nhập. AD dùng sAMAccountName, OpenLDAP dùng uid.
LDAP_USER_FILTER=(sAMAccountName={{username}})
