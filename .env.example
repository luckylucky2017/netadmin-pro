# Sao chép file này thành .env và điền giá trị thật.
#
# Chỉ còn thông tin cần để Node khởi động và kết nối MySQL + bootstrap tài khoản admin đầu tiên.
# Mọi cấu hình khác (kết nối vCenter, tài khoản kết nối SSH, Anthropic API Key, SAML/LDAP SSO) giờ
# quản lý ngay trong ứng dụng sau khi đăng nhập (trang Cụm vCenter / Tài khoản kết nối / Cài đặt),
# lưu trong MySQL và có hiệu lực ngay — không cần đặt trong .env hay khởi động lại server nữa.

# Cổng chạy server (mặc định 3000)
PORT=3000

# ── Database (MySQL) ─────────────────────────────────────────────────────
# Dùng 1 user riêng chỉ có quyền trên đúng 1 database của app, không dùng root cho app.
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=

# ── Đăng nhập & phân quyền ──────────────────────────────────────────────
# Khóa ký session cookie — giữ bí mật, đổi giá trị này sẽ đăng xuất tất cả user đang đăng nhập.
# Tạo 1 chuỗi ngẫu nhiên dài, ví dụ: openssl rand -hex 32
SESSION_SECRET=

# Tài khoản admin đầu tiên — chỉ được tạo 1 lần lúc bảng users còn rỗng. Đổi mật khẩu ngay sau khi
# đăng nhập lần đầu (trang Người dùng), 2 biến này không dùng lại sau đó.
ADMIN_EMAIL=
ADMIN_PASSWORD=
